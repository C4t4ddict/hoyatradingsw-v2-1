EXCHANGE=binance
API_KEY=YOUR_BINANCE_API_KEY
API_SECRET=YOUR_BINANCE_API_SECRET
BINANCE_DEFAULT_TYPE=spot
BINANCE_TESTNET=true
CCXT_TIMEOUT_MS=20000
DRY_RUN=true
WEBHOOK_TOKEN=CHANGE_ME
PERF_LOG=data/performance_log.jsonl

# Risk guardrail
DAILY_LOSS_LIMIT_USDT=30
MAX_CONSECUTIVE_LOSSES=3
DAILY_LOSS_LIMIT_USDT_SPOT=30
MAX_CONSECUTIVE_LOSSES_SPOT=3
DAILY_LOSS_LIMIT_USDT_FUTURES=30
MAX_CONSECUTIVE_LOSSES_FUTURES=3
RISK_STATE_PATH=data/risk_state.json
RISK_STATE_PATH_SPOT=data/risk_state_spot.json
RISK_STATE_PATH_FUTURES=data/risk_state_futures.json
MAX_CONCURRENT_POSITIONS_SPOT=5
MAX_CONCURRENT_POSITIONS_FUTURES=3
SYMBOL_LIMITS_SPOT_JSON={"BTC/USDT":2,"ETH/USDT":2}
SYMBOL_LIMITS_FUTURES_JSON={"BTC/USDT:USDT":1,"ETH/USDT:USDT":1}

# Telegram alert (optional)
ALERT_TELEGRAM_BOT_TOKEN=
ALERT_TELEGRAM_CHAT_ID=

# 전용 모의투자 알림 봇 (미설정 시 ALERT_*로 fallback)
PAPER_ALERT_TELEGRAM_BOT_TOKEN=
PAPER_ALERT_TELEGRAM_CHAT_ID=
IDEMPOTENCY_STORE_PATH=data/idempotency_store.json
IDEMPOTENCY_TTL_HOURS=48
STRATEGY_STORE_PATH=data/strategy_params.json
WEBHOOK_MIN_EXPECTED_RETURN_PCT=-999
WEBHOOK_MAX_ALLOWED_MDD_PCT=999
WEBHOOK_AUTO_SELECT_VERSION=false
WEBHOOK_LIVE_ALLOWED_TAGS=stable
WEBHOOK_TEST_TAG_FORCE_DRY_RUN=true
TRADING_WINDOW_UTC=00:00-23:59
VOL_PAUSE_ENABLED=false
VOL_LOOKBACK_CANDLES=12
VOL_SPIKE_THRESHOLD_PCT=3.0

# v2 시장 인텔리전스 필터 (뉴스/공식발표 기반)
MARKET_INTEL_FILTER_ENABLED=true
MARKET_INTEL_MIN_SCORE=-1.5
MARKET_INTEL_BLOCK_BEARISH=true
MARKET_INTEL_SIZE_UP_BULLISH=1.15
MARKET_INTEL_SIZE_DOWN_BEARISH=0.65
MARKET_INTEL_AUTO_REFRESH_SEC=300
MARKET_INTEL_CACHE_TTL_SEC=300
# 필요 시 신뢰 RSS 추가 (쉼표 구분)
# MARKET_INTEL_EXTRA_RSS=https://example.com/rss,https://example2.com/rss
# 공식 X/트윗 RSS 브릿지 (세미콜론 구분: name|url|trust)
# MARKET_INTEL_TWEET_RSS=FedX|https://rsshub.app/twitter/user/federalreserve|0.95;SECX|https://rsshub.app/twitter/user/secgov|0.9
ML_FILTER_ENABLED=true
ML_MIN_UP_PROBA_4H=0.52
ML_BLOCK_LOW_CONFIDENCE=true
ML_WEIGHT_1H=0.2
ML_WEIGHT_4H=0.5
ML_WEIGHT_24H=0.3
ML_MIN_COMPOSITE_SCORE=0.54
NEWS_TRANSLATION_CACHE_PATH=data/news_translation_cache.json
NEWS_TRANSLATION_CACHE_TTL_SEC=43200
